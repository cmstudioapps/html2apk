{
  "name": "html2apk",
  "version": "12.0.4",
  "author": {
    "name": "Dev Caio Multiversando",
    "email": "dev@caio.local"
  },
  "description": "Node CLI and library to turn an HTML/CSS/JS folder into an Android APK through Cordova.",
  "main": "index.js",
  "bin": {
    "html2apk": "bin/html2apk.js"
  },
  "type": "commonjs",
  "license": "MIT",
  "files": [
    "bin",
    "src",
    "examples/minimal/app.json",
    "examples/minimal/index.html",
    "index.js",
    "html2apk.png",
    "README.md"
  ],
  "scripts": {
    "build": "node bin/html2apk.js build",
    "doctor": "node bin/html2apk.js doctor",
    "desktop": "node bin/html2apk-desktop.js",
    "build-desktop-win": "node scripts/build-desktop-portable.js",
    "build-desktop-deb": "npx electron-builder --linux deb",
    "test": "node --test test/config.test.js",
    "build-win": "pkg . --targets node20-win-x64 --output dist/html2apk.exe",
    "build-linux": "pkg . --targets node20-linux-x64 --output dist/html2apk-linux",
    "build-mac": "pkg . --targets node20-macos-x64 --output dist/html2apk-macos"
  },
  "pkg": {
    "scripts": [
      "src/**/*.js"
    ],
    "assets": [
      "src/templates/**/*"
    ]
  },
  "build": {
    "appId": "dev.caiomultiversando.html2apk",
    "productName": "html2apk",
    "copyright": "Copyright © Dev Caio Multiversando",
    "asar": false,
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "bin/**/*",
      "src/**/*",
      "index.js",
      "package.json",
      "package-lock.json",
      "README.md",
      "html2apk.png",
      "node_modules/**/*"
    ],
    "extraMetadata": {
      "main": "src/desktop/main.js"
    },
    "win": {
      "target": [
        "portable"
      ],
      "icon": "html2apk.png"
    },
    "linux": {
      "target": [
        "deb"
      ],
      "icon": "html2apk.png"
    }
  },
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "pkg": "^5.8.1"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cordova": "^13.0.0",
    "onesignal-cordova-plugin": "^5.3.10"
  }
}
